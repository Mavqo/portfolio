# Required for email notifications (optional — app works without it)
RESTAURANT_EMAIL=ristorante@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Required for production CORS (set to your Vercel frontend URL)
CORS_ORIGIN=https://osteria-bellavista.vercel.app

# Database path (Railway: use /data/osteria.db for persistence)
DATABASE_PATH=/data/osteria.db

# Timezone for date validation (default: Europe/Rome)
RESTAURANT_TZ=Europe/Rome
