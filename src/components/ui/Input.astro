---
import { cn } from '@/lib/utils';

interface Props {
  type?: 'text' | 'email' | 'textarea';
  name: string;
  id: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
  rows?: number;
  value?: string;
}

const { 
  type = 'text',
  name,
  id,
  placeholder,
  required = false,
  class: className,
  rows = 4,
  value
} = Astro.props;

const baseStyles = cn(
  'w-full bg-white/7 border border-white/15 rounded-[12px] px-5 py-3.5',
  'text-white placeholder:text-[#aabbcc]',
  'transition-all duration-200',
  'focus:outline-none focus:border-white/40 focus:shadow-[0_0_0_3px_rgba(255,255,255,0.07)]',
  'dark:bg-white/8 dark:border-white/22',
  className
);
---

{type === 'textarea' ? (
  <textarea
    id={id}
    name={name}
    placeholder={placeholder}
    required={required}
    rows={rows}
    class={baseStyles}
  >{value}</textarea>
) : (
  <input
    type={type}
    id={id}
    name={name}
    placeholder={placeholder}
    required={required}
    value={value}
    class={baseStyles}
  />
)}
