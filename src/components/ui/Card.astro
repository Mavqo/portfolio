---
import { cn } from '@/lib/utils';

interface Props {
  class?: string;
  hover?: boolean;
  padding?: 'none' | 'sm' | 'md' | 'lg';
}

const { 
  class: className,
  hover = true,
  padding = 'md'
} = Astro.props;

const paddings = {
  none: '',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const classes = cn(
  'bg-background border border-border rounded-[12px] overflow-hidden',
  paddings[padding],
  hover && 'transition-all duration-200 hover:-translate-y-1 hover:shadow-lg hover:border-accent',
  className
);
---

<div class={classes}>
  <slot />
</div>
