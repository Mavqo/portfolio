---
---

<section id="testimonials" class="py-20 px-[6%] bg-white dark:bg-slate-900">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold tracking-widest uppercase text-indigo-600 dark:text-indigo-400 mb-3" data-i18n="testimonials.label">
        Cosa dicono i clienti
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4" data-i18n="testimonials.headline">
        Risultati concreti, clienti soddisfatti
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-[560px] mx-auto" data-i18n="testimonials.description">
        Feedback reali da imprenditori e professionisti che hanno migliorato il loro business online.
      </p>
    </div>

    <!-- Testimonials grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-14">

      <!-- Testimonial 1 -->
      <div class="relative flex flex-col rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
        <!-- Quote mark -->
        <svg class="w-8 h-8 text-indigo-200 dark:text-indigo-800 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <p class="flex-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-5" data-i18n="testimonials.items.luca.text">
          "Marco ha trasformato il mio sito da vetrina statica a strumento di acquisizione clienti. In tre mesi ho avuto il 40% di contatti in più dal web."
        </p>
        <div class="flex items-center gap-3 pt-4 border-t border-slate-100 dark:border-slate-700">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-cyan-500 flex items-center justify-center text-white font-bold text-sm flex-shrink-0" aria-hidden="true">
            L
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-white">Luca Ferretti</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Idraulico, Lugano</p>
          </div>
          <!-- Stars -->
          <div class="ml-auto flex gap-0.5" aria-label="5 stelle su 5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
      </div>

      <!-- Testimonial 2 -->
      <div class="relative flex flex-col rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
        <svg class="w-8 h-8 text-indigo-200 dark:text-indigo-800 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <p class="flex-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-5" data-i18n="testimonials.items.sara.text">
          "Il sistema di follow-up automatico ha eliminato quasi tutti i lead persi. Rispondo ora entro 10 minuti, anche di notte."
        </p>
        <div class="flex items-center gap-3 pt-4 border-t border-slate-100 dark:border-slate-700">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center text-white font-bold text-sm flex-shrink-0" aria-hidden="true">
            S
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-white">Sara Monti</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Studio di fisioterapia, Bellinzona</p>
          </div>
          <div class="ml-auto flex gap-0.5" aria-label="5 stelle su 5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
      </div>

      <!-- Testimonial 3 -->
      <div class="relative flex flex-col rounded-2xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 shadow-sm hover:shadow-md transition-shadow duration-300">
        <svg class="w-8 h-8 text-indigo-200 dark:text-indigo-800 mb-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
        </svg>
        <p class="flex-1 text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-5" data-i18n="testimonials.items.roberto.text">
          "Cercavo qualcuno che capisse sia il lato tecnico che quello del business. Marco ha consegnato in tempo, spiegato ogni scelta e il sito converte bene."
        </p>
        <div class="flex items-center gap-3 pt-4 border-t border-slate-100 dark:border-slate-700">
          <div class="w-10 h-10 rounded-full bg-gradient-to-br from-violet-500 to-indigo-500 flex items-center justify-center text-white font-bold text-sm flex-shrink-0" aria-hidden="true">
            R
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-white">Roberto Cann</p>
            <p class="text-xs text-slate-500 dark:text-slate-400">Consulente finanziario, Locarno</p>
          </div>
          <div class="ml-auto flex gap-0.5" aria-label="5 stelle su 5">
            {[...Array(5)].map(() => (
              <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Social proof bar -->
    <div class="rounded-2xl bg-gradient-to-r from-indigo-50 to-cyan-50 dark:from-indigo-900/20 dark:to-cyan-900/20 border border-indigo-100 dark:border-indigo-800/40 p-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl font-bold text-slate-900 dark:text-white">12+</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1" data-i18n="testimonials.stats.clients">Clienti attivi</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-900 dark:text-white">5.0</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1" data-i18n="testimonials.stats.rating">Rating medio</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-900 dark:text-white">3 anni</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1" data-i18n="testimonials.stats.experience">Esperienza</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-slate-900 dark:text-white">100%</p>
          <p class="text-sm text-slate-600 dark:text-slate-400 mt-1" data-i18n="testimonials.stats.delivery">Progetti consegnati</p>
        </div>
      </div>
    </div>
  </div>
</section>
