---
---

<section id="contact" class="py-20 px-[6%] bg-gradient-to-br from-slate-900 to-slate-800 text-white">
  <div class="max-w-[700px] mx-auto text-center">
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4" data-i18n="contact.headline">
      Pronto a far crescere il tuo business?
    </h2>
    <p class="text-base sm:text-lg text-slate-300 mb-6 sm:mb-8" data-i18n="contact.description">
      Scrivimi e rispondo entro 24 ore. Una breve chiacchierata ci aiuta a capire se posso aiutarti.
    </p>

    {/* Email + Calendly CTA */}
    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4 mb-8 sm:mb-10">
      <a
        href="mailto:marco.mongelli@outlook.it"
        class="text-slate-200 hover:text-white transition-colors font-medium underline underline-offset-4"
      >
        marco.mongelli@outlook.it
      </a>
      <span class="hidden sm:block text-white/30">|</span>
      <a
        href="https://www.upwork.com/freelancers/~0161d138ea4dfa699b"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold text-white bg-[#14a800] hover:bg-[#14a800]/90 transition-colors"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.561 13.158c-1.102 0-2.135-.467-3.074-1.227l.228-1.076.008-.042c.207-1.143.849-3.06 2.839-3.06 1.492 0 2.703 1.212 2.703 2.703-.001 1.489-1.211 2.702-2.704 2.702zm0-8.14c-2.539 0-4.51 1.649-5.31 4.366-1.22-1.834-2.148-4.036-2.687-5.892H7.828v7.112c-.002 1.406-1.141 2.546-2.547 2.546-1.405 0-2.543-1.14-2.543-2.546V3.492H0v7.112c0 2.914 2.37 5.303 5.281 5.303 2.913 0 5.283-2.389 5.283-5.303v-1.19c.529 1.107 1.182 2.229 1.974 3.221l-1.673 7.873h2.797l1.213-5.71c1.063.679 2.285 1.109 3.686 1.109 3.139 0 5.689-2.571 5.689-5.711-.001-3.142-2.551-5.713-5.689-5.713z"/>
        </svg>
        <span data-i18n="contact.callCta">Message me on Upwork →</span>
      </a>
    </div>

    <form
      id="contact-form"
      action="https://formspree.io/f/mgonqyyw"
      method="POST"
      class="space-y-4 text-left"
    >
      <div class="grid sm:grid-cols-2 gap-4">
        <input
          type="text"
          name="name"
          placeholder="Il tuo nome"
          required
          class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:border-indigo-400 focus:bg-white/15 transition-colors"
          data-i18n-placeholder="contact.form.namePlaceholder"
        />
        <input
          type="email"
          name="email"
          placeholder="La tua email"
          required
          class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:border-indigo-400 focus:bg-white/15 transition-colors"
          data-i18n-placeholder="contact.form.emailPlaceholder"
        />
      </div>

      <div>
        <label for="project-type" class="sr-only" data-i18n="contact.projectType.label">Project type</label>
        <select
          id="project-type"
          name="project-type"
          required
          class="custom-select w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white focus:outline-none focus:border-indigo-400 focus:bg-white/15 transition-colors appearance-none cursor-pointer"
        >
          <option value="" disabled selected data-i18n="contact.projectType.placeholder">Select project type</option>
          <option value="sito-web" data-i18n="contact.projectType.web">Website</option>
          <option value="automazione-ai" data-i18n="contact.projectType.ai">AI Automation</option>
          <option value="consulenza" data-i18n="contact.projectType.consulting">Consulting</option>
          <option value="altro" data-i18n="contact.projectType.other">Other</option>
        </select>
      </div>

      <textarea
        name="message"
        placeholder="Raccontami del tuo progetto"
        rows="5"
        required
        class="w-full px-4 py-3 bg-white/10 border border-white/30 rounded-lg text-white placeholder-white/60 focus:outline-none focus:border-indigo-400 focus:bg-white/15 transition-colors resize-none"
        data-i18n-placeholder="contact.form.messagePlaceholder"
      ></textarea>

      <div class="text-center">
        <button
          type="submit"
          class="w-full sm:w-auto px-8 py-4 bg-white text-slate-900 font-semibold rounded-lg hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-white/50 transition-colors"
          data-i18n="contact.form.submit"
        >
          Invia messaggio →
        </button>
      </div>

      {/* Trust badges */}
      <div class="flex flex-wrap justify-center gap-3 pt-2">
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-xs text-slate-200">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span data-i18n="contact.trust.response">Reply within 24h</span>
        </div>
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-xs text-slate-200">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          <span data-i18n="contact.trust.freeCall">Free intro call</span>
        </div>
        <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/10 border border-white/20 text-xs text-slate-200">
          <svg class="w-3.5 h-3.5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span data-i18n="contact.trust.noCommitment">No commitment</span>
        </div>
      </div>
    </form>

    {/* Success message (hidden by default) */}
    <div id="contact-success" class="hidden mt-8 p-6 bg-green-500/20 border border-green-500/40 rounded-lg">
      <div class="text-green-400 mb-2">
        <svg class="w-10 h-10 sm:w-12 sm:h-12 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <h3 class="text-lg sm:text-xl font-bold mb-2" data-i18n="contact.success.title">Grazie!</h3>
      <p class="text-slate-300" data-i18n="contact.success.message">Ho ricevuto il tuo messaggio e ti risponderò al più presto.</p>
    </div>

    {/* Social links */}
    <div class="flex justify-center gap-4 mt-10">
      <a href="https://www.linkedin.com/in/marco-mongelli-618639180/" class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center hover:bg-white/25 focus:outline-none focus:ring-2 focus:ring-white/30 transition-colors" aria-label="LinkedIn">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://github.com/Mavqo" class="w-12 h-12 rounded-full bg-white/15 flex items-center justify-center hover:bg-white/25 focus:outline-none focus:ring-2 focus:ring-white/30 transition-colors" aria-label="GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .custom-select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='rgba(255,255,255,0.6)' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.75rem center;
    background-repeat: no-repeat;
    background-size: 1.25rem;
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const successMsg = document.getElementById('contact-success');
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;

  // Get translations for button states
  function getButtonText(key: string, fallback: string): string {
    if (window.i18n && typeof window.i18n.t === 'function') {
      return window.i18n.t(key, fallback);
    }
    return fallback;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const originalText = submitBtn?.textContent || getButtonText('contact.form.submit', 'Invia messaggio →');
    const sendingText = getButtonText('contact.form.sending', 'Invio...');
    const errorText = getButtonText('contact.form.error', 'Errore — riprova');

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = sendingText;
    }

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { 'Accept': 'application/json' }
      });

      if (res.ok) {
        form.style.display = 'none';
        successMsg?.classList.remove('hidden');
      } else {
        if (submitBtn) {
          submitBtn.textContent = errorText;
          submitBtn.disabled = false;
        }
      }
    } catch {
      if (submitBtn) {
        submitBtn.textContent = errorText;
        submitBtn.disabled = false;
      }
    }
  });
</script>
