---

<section class="py-16 px-[6%] bg-slate-900">
  <div class="max-w-[1100px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">

      <div class="flex flex-col items-center gap-2 px-6 py-8 rounded-xl border border-white/10 bg-white/5">
        <span
          class="text-5xl font-bold text-indigo-400"
          data-i18n="about.stats.experience.value"
        >5+</span>
        <span
          class="text-sm font-medium text-slate-300 uppercase tracking-widest"
          data-i18n="about.stats.experience.label"
        >Years Experience</span>
      </div>

      <div class="flex flex-col items-center gap-2 px-6 py-8 rounded-xl border border-white/10 bg-white/5">
        <span
          class="text-5xl font-bold text-indigo-400"
          data-i18n="about.stats.projects.value"
        >20+</span>
        <span
          class="text-sm font-medium text-slate-300 uppercase tracking-widest"
          data-i18n="about.stats.projects.label"
        >Projects Shipped</span>
      </div>

      <div class="flex flex-col items-center gap-2 px-6 py-8 rounded-xl border border-white/10 bg-white/5">
        <span
          class="text-5xl font-bold text-indigo-400"
          data-i18n="about.stats.clients.value"
        >Global</span>
        <span
          class="text-sm font-medium text-slate-300 uppercase tracking-widest"
          data-i18n="about.stats.clients.label"
        >Upwork Freelancer</span>
      </div>

    </div>
  </div>
</section>
