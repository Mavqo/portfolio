---
---

<section id="work" class="py-20 px-[6%] bg-slate-50 dark:bg-slate-900/50">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold tracking-widest uppercase text-indigo-600 dark:text-indigo-400 mb-3" data-i18n="projects.label">
        I miei lavori
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4" data-i18n="projects.headline">
        Progetti recenti
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-[600px] mx-auto" data-i18n="projects.description">
        Esempi concreti di siti web e automazioni realizzati per clienti
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {/* Osteria Bellavista */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          {/* Screenshot reale con frame browser */}
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            {/* Browser chrome */}
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            {/* Mock screenshot */}
            <div class="h-[calc(100%-28px)] overflow-hidden relative mock-screenshot-osteria">
              <div class="absolute inset-0 bg-gradient-to-br from-amber-900 via-slate-900 to-orange-900"></div>
              <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-20 h-20 rounded-full bg-amber-500/20 blur-xl"></div>
              <div class="absolute bottom-1/3 left-1/4 w-16 h-16 rounded-full bg-orange-500/15 blur-lg"></div>
              <div class="absolute bottom-1/4 right-1/3 w-12 h-12 rounded-full bg-white/10 blur-md"></div>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <div class="w-3/4 h-2 bg-white/10 rounded mb-2"></div>
                <div class="w-1/2 h-2 bg-white/10 rounded mb-4"></div>
                <span class="text-white/90 font-bold text-base tracking-tight">Osteria Bellavista</span>
              </div>
              {/* Hover overlay */}
              <div class="absolute inset-0 bg-slate-900/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3">
                <a
                  href="https://osteria.mavqo.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-white text-slate-900 rounded-lg hover:bg-slate-100 transition-colors"
                  data-i18n="projects.items.osteria.cta"
                >
                  Live Demo →
                </a>
                <a
                  href="https://github.com/Mavqo/osteria-bellavista"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-slate-800 text-white border border-slate-600 rounded-lg hover:bg-slate-700 transition-colors"
                >
                  GitHub
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 rounded">Live</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Full Stack</span>
            <span class="px-2 py-1 text-xs font-medium bg-orange-100 dark:bg-orange-900/50 text-orange-700 dark:text-orange-300 rounded">Astro</span>
            <span class="px-2 py-1 text-xs font-medium bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 rounded">React</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">i18n</span>
            <span class="px-2 py-1 text-xs font-medium bg-cyan-100 dark:bg-cyan-900/50 text-cyan-700 dark:text-cyan-300 rounded">Docker</span>
          </div>

          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.osteria.title">
            Osteria Bellavista — Restaurant Website
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.osteria.description">
            Elegant and functional website for an Italian restaurant. Online reservations, digital menu, and social media integration.
          </p>

          <a
            href="https://osteria.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.osteria.cta"
          >
            Live Demo →
          </a>
        </div>
      </div>

      {/* LeadSpark */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          {/* Mock screenshot con frame browser */}
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            {/* Browser chrome */}
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            {/* Mock screenshot */}
            <div class="h-[calc(100%-28px)] overflow-hidden relative mock-screenshot-leadspark">
              <div class="absolute inset-0 bg-gradient-to-br from-indigo-900 via-slate-900 to-emerald-900"></div>
              <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-24 h-24 rounded-full bg-indigo-500/20 blur-xl"></div>
              <div class="absolute top-1/3 left-1/4 w-16 h-16 rounded-full bg-emerald-500/15 blur-lg"></div>
              <div class="absolute bottom-1/4 right-1/4 w-20 h-20 rounded-full bg-blue-500/15 blur-lg"></div>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <div class="w-3/4 h-2 bg-white/10 rounded mb-2"></div>
                <div class="w-1/2 h-2 bg-white/10 rounded mb-4"></div>
                <span class="text-white/90 font-bold text-lg tracking-tight">LeadSpark</span>
              </div>
              {/* Hover overlay */}
              <div class="absolute inset-0 bg-slate-900/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3">
                <a
                  href="https://leads.mavqo.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-white text-slate-900 rounded-lg hover:bg-slate-100 transition-colors"
                  data-i18n="projects.items.leadspark.cta"
                >
                  Live Demo →
                </a>
                <a
                  href="https://github.com/Mavqo/leadspark"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-slate-800 text-white border border-slate-600 rounded-lg hover:bg-slate-700 transition-colors"
                >
                  GitHub
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 rounded">Live</span>
            <span class="px-2 py-1 text-xs font-medium bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded">AI & Automation</span>
            <span class="px-2 py-1 text-xs font-medium bg-orange-100 dark:bg-orange-900/50 text-orange-700 dark:text-orange-300 rounded">Astro</span>
            <span class="px-2 py-1 text-xs font-medium bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 rounded">React</span>
            <span class="px-2 py-1 text-xs font-medium bg-cyan-100 dark:bg-cyan-900/50 text-cyan-700 dark:text-cyan-300 rounded">OpenAI</span>
            <span class="px-2 py-1 text-xs font-medium bg-orange-100 dark:bg-orange-900/50 text-orange-700 dark:text-orange-300 rounded">n8n</span>
          </div>

          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.leadspark.title">
            LeadSpark
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.leadspark.description">
            Piattaforma completa per cattura, qualifica e gestione lead. Automazione follow-up, scoring e integrazione CRM.
          </p>

          <a
            href="https://leads.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.leadspark.cta"
          >
            Live Demo →
          </a>
        </div>
      </div>

      {/* MediAnalytics Pro */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          {/* Mock screenshot con frame browser */}
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            {/* Browser chrome */}
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            {/* Mock screenshot */}
            <div class="h-[calc(100%-28px)] overflow-hidden relative mock-screenshot-analytics">
              <div class="absolute inset-0 bg-gradient-to-br from-violet-900 via-slate-900 to-cyan-900"></div>
              <div class="absolute top-8 left-4 right-4 h-12 flex items-end justify-between gap-2">
                <div class="w-1/5 h-4 bg-white/15 rounded-t"></div>
                <div class="w-1/5 h-8 bg-white/20 rounded-t"></div>
                <div class="w-1/5 h-6 bg-white/10 rounded-t"></div>
                <div class="w-1/5 h-10 bg-white/25 rounded-t"></div>
                <div class="w-1/5 h-5 bg-white/15 rounded-t"></div>
              </div>
              <div class="absolute top-24 left-4 right-4 h-px bg-white/10"></div>
              <div class="absolute top-28 left-4 right-4 flex items-center gap-2">
                <div class="w-2 h-2 rounded-full bg-cyan-400/60"></div>
                <div class="w-16 h-1.5 bg-white/10 rounded"></div>
              </div>
              <div class="absolute bottom-6 left-4 right-4 flex items-center justify-center">
                <span class="text-white/90 font-bold text-base tracking-tight">MediAnalytics Pro</span>
              </div>
              {/* Hover overlay */}
              <div class="absolute inset-0 bg-slate-900/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-3">
                <a
                  href="https://analytics.mavqo.dev"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-white text-slate-900 rounded-lg hover:bg-slate-100 transition-colors"
                  data-i18n="projects.items.medianalytics.cta"
                >
                  Live Demo →
                </a>
                <a
                  href="https://github.com/Mavqo/medianalytics-pro"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium bg-slate-800 text-white border border-slate-600 rounded-lg hover:bg-slate-700 transition-colors"
                >
                  GitHub
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-emerald-100 dark:bg-emerald-900/50 text-emerald-700 dark:text-emerald-300 rounded">Live</span>
            <span class="px-2 py-1 text-xs font-medium bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 rounded">SaaS Dashboard</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-700 dark:text-slate-300 rounded">Next.js</span>
            <span class="px-2 py-1 text-xs font-medium bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 rounded">React</span>
            <span class="px-2 py-1 text-xs font-medium bg-cyan-100 dark:bg-cyan-900/50 text-cyan-700 dark:text-cyan-300 rounded">TypeScript</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">shadcn/ui</span>
          </div>

          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.medianalytics.title">
            MediAnalytics Pro
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.medianalytics.description">
            Professional analytics dashboard for healthcare & wellness centers. Patient management, appointment scheduling, KPI tracking, and billing — all in one place.
          </p>

          <a
            href="https://analytics.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.medianalytics.cta"
          >
            Live Demo →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .mock-screenshot-osteria,
  .mock-screenshot-leadspark,
  .mock-screenshot-analytics {
    transition: transform 0.5s ease;
  }
  .group:hover .mock-screenshot-osteria,
  .group:hover .mock-screenshot-leadspark,
  .group:hover .mock-screenshot-analytics {
    transform: scale(1.05);
  }
</style>
