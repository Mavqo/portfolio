---
---

<section id="work" class="py-20 px-[6%] bg-slate-50 dark:bg-slate-900/50">
  <div class="max-w-[1100px] mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-semibold tracking-widest uppercase text-indigo-600 dark:text-indigo-400 mb-3" data-i18n="projects.label">
        I miei lavori
      </p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4" data-i18n="projects.headline">
        Progetti recenti
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-[600px] mx-auto" data-i18n="projects.description">
        Esempi concreti di siti web e automazioni realizzati per clienti
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {/* Osteria Bellavista */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          {/* Screenshot reale con frame browser */}
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            {/* Browser chrome */}
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            {/* Screenshot reale */}
            <div class="h-[calc(100%-28px)] overflow-hidden">
              <img 
                src="/assets/osteria-real.png" 
                alt="Osteria Bellavista website" 
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          </div>
        </div>
        
        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded">Showcase</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Web App</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">React</span>
          </div>
          
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.osteria.title">
            Osteria Bellavista — Ristorante a Bissone
          </h3>
          
          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.osteria.description">
            Sito web elegante e funzionale per un ristorante italiano sul Lago di Lugano. Prenotazioni online, menu digitale e integrazione con i social.
          </p>
          
          <a 
            href="https://osteria.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.osteria.cta"
          >
            Vedi il progetto →
          </a>
        </div>
      </div>
      
      {/* CRM Automation */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            <div class="h-[calc(100%-28px)] overflow-hidden">
              <img
                src="/assets/crm-real.png"
                alt="CRM Automation dashboard"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          </div>
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded">Showcase</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Automazione</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">n8n</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.crm.title">
            CRM Automation
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.crm.description">
            Sistema di automazione per gestione lead e follow-up automatici.
          </p>

          <a
            href="https://leads.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.crm.cta"
          >
            Vedi il progetto →
          </a>
        </div>
      </div>

      {/* Dashboard Analytics */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          <div class="relative bg-slate-900 rounded-t-lg h-full overflow-hidden">
            <div class="flex gap-1.5 px-3 py-2 border-b border-slate-700">
              <div class="w-2.5 h-2.5 rounded-full bg-red-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-yellow-500"></div>
              <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            </div>
            <div class="h-[calc(100%-28px)] overflow-hidden">
              <img
                src="/assets/dashboard-real.png"
                alt="Dashboard Analytics"
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            </div>
          </div>
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-indigo-100 dark:bg-indigo-900/50 text-indigo-700 dark:text-indigo-300 rounded">Showcase</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Dashboard</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Python</span>
          </div>
          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.dashboard.title">
            Dashboard Analytics
          </h3>
          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.dashboard.description">
            Visualizzazione dati e report automatici per piccole imprese.
          </p>

          <a
            href="https://analytics.mavqo.dev"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:gap-3 transition-all"
            data-i18n="projects.items.dashboard.cta"
          >
            Vedi il progetto →
          </a>
        </div>
      </div>

      {/* Job Site Checklist iOS */}
      <div class="group bg-white dark:bg-slate-800 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700 hover:shadow-xl transition-all duration-300">
        <div class="h-48 bg-slate-100 dark:bg-slate-900 p-3">
          <div class="relative bg-gradient-to-br from-slate-900 to-violet-950 rounded-lg h-full overflow-hidden flex items-center justify-center">
            {/* Phone frame mockup */}
            <div class="relative flex flex-col items-center">
              <div class="w-20 h-36 rounded-2xl border-2 border-violet-400/60 bg-slate-900/80 flex flex-col overflow-hidden shadow-lg">
                <div class="h-4 bg-slate-800 flex items-center justify-center">
                  <div class="w-6 h-1 rounded-full bg-slate-600"></div>
                </div>
                <div class="flex-1 p-1.5 space-y-1">
                  <div class="h-2 bg-violet-500/70 rounded-sm w-full"></div>
                  <div class="h-1.5 bg-slate-600/70 rounded-sm w-3/4"></div>
                  <div class="h-1.5 bg-slate-600/70 rounded-sm w-full"></div>
                  <div class="h-1.5 bg-slate-600/70 rounded-sm w-2/3"></div>
                  <div class="mt-1 h-8 bg-violet-900/60 rounded-sm w-full flex items-center justify-center">
                    <div class="w-4 h-4 rounded-sm border border-violet-400/50"></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute bottom-2 right-2 flex gap-1">
              <span class="px-1.5 py-0.5 text-[9px] font-medium bg-violet-500/30 text-violet-300 rounded border border-violet-500/30">SwiftUI</span>
              <span class="px-1.5 py-0.5 text-[9px] font-medium bg-slate-700/60 text-slate-400 rounded border border-slate-600/30">SwiftData</span>
            </div>
          </div>
        </div>

        <div class="p-6">
          <div class="flex flex-wrap gap-2 mb-3">
            <span class="px-2 py-1 text-xs font-medium bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 rounded" data-i18n="projects.items.jobsite.tag">Capability Demo</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">SwiftUI</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">AVFoundation</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">Core Location</span>
            <span class="px-2 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 rounded">SwiftData</span>
          </div>

          <h3 class="text-lg font-bold text-slate-900 dark:text-white mb-2" data-i18n="projects.items.jobsite.title">
            Job Site Checklist + Photo Log
          </h3>

          <p class="text-slate-600 dark:text-slate-400 text-sm mb-4" data-i18n="projects.items.jobsite.description">
            Today list, job-detail checklist with photo timeline, geo-stamped camera capture, one-tap PDF share.
          </p>

          <a
            href="https://github.com/Mavqo/jobsite-checklist-ios"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-sm font-medium text-violet-600 dark:text-violet-400 hover:gap-3 transition-all"
            data-i18n="projects.items.jobsite.cta"
          >
            View on GitHub →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
