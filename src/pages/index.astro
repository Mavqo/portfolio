---
import MainLayout from '@/layouts/MainLayout.astro';
import Hero from '@/components/sections/Hero.astro';
import Problems from '@/components/sections/Problems.astro';
import Services from '@/components/sections/Services.astro';
import SocialProof from '@/components/sections/SocialProof.astro';
import Process from '@/components/sections/Process.astro';
import Projects from '@/components/sections/Projects.astro';
import About from '@/components/sections/About.astro';
import Contact from '@/components/sections/Contact.astro';
---

<MainLayout
  title="Marco — Full Stack Developer & AI Engineer | Upwork"
  description="Freelance Full Stack developer and AI automation specialist on Upwork. I help startups and SaaS companies ship faster with modern web apps and intelligent workflows."
  lang="en"
>
  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Marco Mongelli",
      "jobTitle": "Full Stack Developer & AI Engineer",
      "url": "https://mavqo.dev",
      "email": "marco.mongelli@outlook.it",
      "sameAs": [
        "https://github.com/Mavqo",
        "https://www.upwork.com/freelancers/~mavqo"
      ],
      "knowsAbout": ["React", "Astro", "Next.js", "FastAPI", "Python", "TypeScript", "AI Automation", "n8n", "LangChain", "OpenAI API", "PostgreSQL", "Docker"],
      "offers": [
        {
          "@type": "Offer",
          "name": "Full Stack Web Development",
          "description": "Production-ready web applications using React, Astro, Next.js, FastAPI"
        },
        {
          "@type": "Offer",
          "name": "AI & Automation Pipelines",
          "description": "n8n workflows, LangChain RAG pipelines, OpenAI API integration"
        }
      ]
    }
  </script>

  <Hero />
  <Problems />
  <Services />
  <SocialProof />
  <Process />
  <Projects />
  <About />
  <Contact />
</MainLayout>