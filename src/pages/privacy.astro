---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Privacy Policy | Marco Digital Agency">
  <section class="py-20 px-[6%] bg-slate-50 dark:bg-slate-900 min-h-[70vh]">
    <div class="max-w-[780px] mx-auto">
      <p class="text-sm font-semibold tracking-widest uppercase text-indigo-600 dark:text-indigo-400 mb-3">
        Legal
      </p>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-6">
        Privacy Policy
      </h1>

      <div class="space-y-5 text-slate-700 dark:text-slate-300 leading-relaxed">
        <p>
          This website collects only the information you voluntarily submit through the contact form
          (name, email, and message) to answer your request.
        </p>
        <p>
          Data is used exclusively for communication related to your inquiry and is not sold or shared
          with third parties for marketing purposes.
        </p>
        <p>
          To request access, correction, or deletion of your submitted data, contact:
          <a class="text-indigo-600 dark:text-indigo-400 underline ml-1" href="mailto:marco.mongelli@outlook.it">
            marco.mongelli@outlook.it
          </a>.
        </p>
      </div>
    </div>
  </section>
</MainLayout>
